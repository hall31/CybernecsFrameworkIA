# Epic10 - Configuration des agents d'IA autonome
# Copiez ce fichier vers .env et configurez vos clés API

# OpenAI Configuration
OPENAI_API_KEY=your_openai_api_key_here
OPENAI_MODEL=gpt-4-turbo-preview

# LangChain Configuration
LANGCHAIN_TRACING_V2=true
LANGCHAIN_ENDPOINT=https://api.smith.langchain.com
LANGCHAIN_API_KEY=your_langchain_api_key_here
LANGCHAIN_PROJECT=epic10-mon-shipfast

# Base de données et cache
REDIS_URL=redis://localhost:6379
MONGODB_URI=mongodb://localhost:27017/epic10
DATABASE_URL=postgresql://user:password@localhost/epic10

# APIs externes (optionnel)
STRIPE_SECRET_KEY=your_stripe_secret_key
GOOGLE_ANALYTICS_ID=your_ga_id
INTERCOM_ACCESS_TOKEN=your_intercom_token
ZENDESK_API_TOKEN=your_zendesk_token

# Monitoring et alertes
SENTRY_DSN=your_sentry_dsn
PROMETHEUS_PORT=9090

# Configuration des agents
PRODUCT_FEEDBACK_AGENT_ENABLED=true
AUTO_ITERATION_AGENT_ENABLED=true
BUSINESS_OPTIMIZER_AGENT_ENABLED=true

# Seuils d'optimisation
CAC_THRESHOLD=50
LTV_THRESHOLD=200
CHURN_THRESHOLD=0.05
ROI_MIN_THRESHOLD=3.0

# Logging
LOG_LEVEL=INFO
LOG_FORMAT=json

# Configuration de l'environnement Core Engine

# API Configuration
API_HOST=0.0.0.0
API_PORT=8000
API_DEBUG=true

# Logging
LOG_LEVEL=INFO
LOG_FORMAT=detailed

# CEO Agent Configuration
CEO_AGENT_TIMEOUT=30
CEO_AGENT_MAX_ITERATIONS=3

# Development
PYTHONPATH=/app
PYTHONUNBUFFERED=1
