# Configuration Epic 9 - Infrastructure DevOps
# Copiez ce fichier vers .env et configurez vos valeurs

# Configuration Kubernetes
KUBERNETES_CLUSTER_PROVIDER=GKE
KUBERNETES_REGION=europe-west1
KUBERNETES_NODE_COUNT=3
KUBERNETES_NODE_TYPE=e2-standard-2

# Configuration Auto-scaling
HPA_MIN_REPLICAS=2
HPA_MAX_REPLICAS=20
HPA_CPU_THRESHOLD=70
HPA_MEMORY_THRESHOLD=80

# Configuration Monitoring
PROMETHEUS_STORAGE_SIZE=50Gi
PROMETHEUS_RETENTION_DAYS=15
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=admin123

# Configuration Alertes
ALERT_CPU_WARNING=70
ALERT_CPU_CRITICAL=80
ALERT_MEMORY_WARNING=75
ALERT_MEMORY_CRITICAL=85
ALERT_ERROR_RATE_WARNING=2
ALERT_ERROR_RATE_CRITICAL=5
ALERT_RESPONSE_TIME_WARNING=1.5
ALERT_RESPONSE_TIME_CRITICAL=2.0
ALERT_UPTIME_CRITICAL=99.9

# Configuration Notifications
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/YOUR_SLACK_WEBHOOK
SLACK_CHANNEL=#alerts
SLACK_CRITICAL_CHANNEL=#critical-alerts

EMAIL_ADMIN=admin@startup.com
EMAIL_DEVOPS=devops@startup.com

DISCORD_WEBHOOK_URL=https://discord.com/api/webhooks/YOUR_DISCORD_WEBHOOK
DISCORD_CHANNEL=alerts

# Configuration SSL
SSL_PROVIDER=cert-manager
SSL_ISSUER=letsencrypt-prod
SSL_EMAIL=admin@startup.com

# Configuration LoadBalancer
INGRESS_CLASS=nginx
INGRESS_ANNOTATIONS=nginx.ingress.kubernetes.io/ssl-redirect:true

# Configuration Logs
LOG_LEVEL=INFO
LOG_FORMAT=%(asctime)s - %(name)s - %(levelname)s - %(message)s

# Configuration Performance
DEPLOYMENT_TIMEOUT=300
SCALING_COOLDOWN_UP=300
SCALING_COOLDOWN_DOWN=300
=======
# Epic10 - Configuration des agents d'IA autonome
# Copiez ce fichier vers .env et configurez vos clés API

# OpenAI Configuration
OPENAI_API_KEY=your_openai_api_key_here
OPENAI_MODEL=gpt-4-turbo-preview

# LangChain Configuration
LANGCHAIN_TRACING_V2=true
LANGCHAIN_ENDPOINT=https://api.smith.langchain.com
LANGCHAIN_API_KEY=your_langchain_api_key_here
LANGCHAIN_PROJECT=epic10-mon-shipfast

# Base de données et cache
REDIS_URL=redis://localhost:6379
MONGODB_URI=mongodb://localhost:27017/epic10
DATABASE_URL=postgresql://user:password@localhost/epic10

# APIs externes (optionnel)
STRIPE_SECRET_KEY=your_stripe_secret_key
GOOGLE_ANALYTICS_ID=your_ga_id
INTERCOM_ACCESS_TOKEN=your_intercom_token
ZENDESK_API_TOKEN=your_zendesk_token

# Monitoring et alertes
SENTRY_DSN=your_sentry_dsn
PROMETHEUS_PORT=9090

# Configuration des agents
PRODUCT_FEEDBACK_AGENT_ENABLED=true
AUTO_ITERATION_AGENT_ENABLED=true
BUSINESS_OPTIMIZER_AGENT_ENABLED=true

# Seuils d'optimisation
CAC_THRESHOLD=50
LTV_THRESHOLD=200
CHURN_THRESHOLD=0.05
ROI_MIN_THRESHOLD=3.0

# Logging
LOG_LEVEL=INFO
LOG_FORMAT=json

# Configuration de l'environnement Core Engine

# API Configuration
API_HOST=0.0.0.0
API_PORT=8000
API_DEBUG=true

# Logging
LOG_LEVEL=INFO
LOG_FORMAT=detailed

# CEO Agent Configuration
CEO_AGENT_TIMEOUT=30
CEO_AGENT_MAX_ITERATIONS=3

# Development
PYTHONPATH=/app
PYTHONUNBUFFERED=1
